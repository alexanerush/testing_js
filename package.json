{
  "name": "auto-testing-repo",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "mocha utils/test/**/*.test.js --reporter mochawesome --reporter-options reportDir=reports,reportFilename=test-report,html=true",
    "coverage": "c8 mocha utils/test/**/*.test.js"
  },
  "devDependencies": {
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "c8": "^8.0.1"
  }
}

